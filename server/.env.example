# 华为云 IoTDA 配置（必须修改为真实值！）
HUAWEI_PROJECT_ID=your-project-id-here
HUAWEI_REGION=cn-north-4
HUAWEI_IOTDA_INSTANCE_ID=your-instance-id-here
HUAWEI_ACCESS_KEY=your-access-key-here
HUAWEI_SECRET_KEY=your-secret-key-here
HUAWEI_ENDPOINT=iotda.cn-north-4.myhuaweicloud.com

# 数据库配置（SQLite，无需修改）
DATABASE_URL=sqlite+aiosqlite:///./app.db

# 应用配置
DEBUG=True
HOST=0.0.0.0
PORT=8000
