# ESP8266 IoT 服务器配置
# 复制此文件为 .env 并填写实际值

# 服务器配置
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./iot_data.db

# 华为云 IoTDA 配置
# AK/SK 在华为云控制台 → 我的凭证 → 访问密钥 获取
HUAWEI_ACCESS_KEY=your-ak-here
HUAWEI_SECRET_KEY=your-sk-here
HUAWEI_REGION=cn-east-3
HUAWEI_PROJECT_ID=your-project-id
HUAWEI_ENDPOINT=923924d24d.st1.iotda-device.cn-east-3.myhuaweicloud.com

# OTA 固件目录
FIRMWARE_DIR=./firmware
RELEASES_DIR=./releases
